#!/usr/bin/env bash
bash -n "$0" | exit 1

source ${TESTSROOTDIR}/tools/runit_common.sh

# If rowids aren't unique then this could return the wrong count
function test_comdb2_files_select_with_two_rowsets() {
	(
		set -e

		# Given
		local -r dbname=$1 dbdir=$2 tablename=$3
		local num_files_with_known_type
		num_files_with_known_type=$(cdb2sql -tabs $dbname local "select count(*) from $tablename where type!='unknown'")
		readonly num_files_with_known_type

		echo "bork" > $dbdir/find_me
		trap "rm $dbdir/find_me" EXIT

		# When
		local num_files
		num_files=$(cdb2sql -tabs $dbname local \
			"select count(*) from comdb2_files where type!='unknown' or filename='find_me'")

		# Then
		(( num_files == num_files_with_known_type+1 ))
	)
}

function test_comdb2_files_select_with_type_constraint() {
	(
		set -e

		# Given
		local -r dbname=$1 dbdir=$2 tablename=$3

		# When
		local types
		types=$(cdb2sql -tabs $dbname local "select distinct(type) from $tablename where type='log'")

		# Then
		[[ "$types" == "log" ]]
	)
}

function test_comdb2_files_select_with_like_and_eq_constraints() {
	(
		set -e

		# Given
		local -r dbname=$1 dbdir=$2 tablename=$3
		echo "bork" | tee $dbdir/please_match_me $dbdir/match $dbdir/woof_i_am_doge > /dev/null
		trap "rm $dbdir/please_match_me $dbdir/match $dbdir/woof_i_am_doge" EXIT

		local filenames
		filenames=$(cdb2sql -tabs $dbname local \
			"select filename from $tablename where filename='%match%' or filename like 'woof%'")

		# Then
		! grep -oP 'please_match_me' <<< "$filenames" > /dev/null
		! grep -oP 'match' <<< "$filenames" > /dev/null
		grep -oP 'woof_i_am_doge' <<< "$filenames" > /dev/null
	)
}

function test_comdb2_files_select_with_like_constraints() {
	(
		set -e

		# Given
		local -r dbname=$1 dbdir=$2 tablename=$3
		echo "bork" | tee $dbdir/please_match_me $dbdir/match $dbdir/woof > /dev/null
		trap "rm $dbdir/please_match_me $dbdir/match $dbdir/woof" EXIT

		local filenames
		filenames=$(cdb2sql -tabs $dbname local \
