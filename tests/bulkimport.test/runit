#!/usr/bin/env bash
bash -n "$0" | exit 1

source fixtures.sh
source constants.sh
source util.sh

function test_flip_flop_import() {
	(
		local src_tbl dst_tbl
		fixture_src_tbl_and_dst_tbl_are_the_same src_tbl dst_tbl
		trap "query_src_db 'drop table $src_tbl'; query_dst_db 'drop table $dst_tbl'" EXIT

		# When
		query_dst_db "import $src_tbl from $SRC_DBNAME to $dst_tbl" && \
		query_dst_db "insert into $dst_tbl select * from $dst_tbl" && \
		query_src_db "import $dst_tbl from $DST_DBNAME to $src_tbl" && \
		query_src_db "insert into $src_tbl select * from $src_tbl" && \
		query_dst_db "import $src_tbl from $SRC_DBNAME to $dst_tbl"

		# Then
		rc=$? && verify_import $src_tbl $dst_tbl
	)
}

function run_basic_test() {
	(
		# Given
		local src_tbl dst_tbl
		$1 src_tbl dst_tbl
		trap "query_src_db 'drop table $src_tbl'; query_dst_db 'drop table $dst_tbl'" EXIT

		# When
		query_dst_db "import $src_tbl from $SRC_DBNAME to $dst_tbl" 

		# Then
		rc=$? && verify_import $src_tbl $dst_tbl
	)
}

function test_basic() {
	for fixture in $FIXTURES;
	do
		run_basic_test $fixture
		rc=$?

		if (( rc != 0 ));
		then
			echo "Failed $FUNCNAME with $fixture"
			return $rc
		fi
	done
}

TESTS=$(compgen -A function | grep -oh "test_\w*")

function main() {
	for testcase in $TESTS;
	do
		$testcase
		failexit $? "Failed $testcase"
	done
}

main
