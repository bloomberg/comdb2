#!/usr/bin/env bash
bash -n "$0" | exit 1

exec 1>/dev/null

source fixtures.sh
source constants.sh
source util.sh

function test_flip_flop_import() {
	(
		# Given
		local src_tbl dst_tbl
		fixture_src_tbl_and_dst_tbl_are_the_same src_tbl dst_tbl
		trap "query_src_db 'drop table $src_tbl'; query_dst_db 'drop table $dst_tbl'" EXIT

		# When
		query_dst_db "import $src_tbl from LOCAL_$SRC_DBNAME to $dst_tbl" && \
		query_dst_db "insert into $dst_tbl select * from $dst_tbl" && \
		query_src_db "import $dst_tbl from LOCAL_$DST_DBNAME to $src_tbl" && \
		query_src_db "insert into $src_tbl select * from $src_tbl" && \
		query_dst_db "import $src_tbl from LOCAL_$SRC_DBNAME to $dst_tbl"

		# Then
		verify $? $src_tbl $dst_tbl
	)
}

function test_import_many_tables_over_table() {
	(
		# Given
		local src_tbl_1 src_tbl_2 src_tbl_3 dst_tbl
		src_tbl_1=foo src_tbl_2=bar src_tbl_3=baz dst_tbl=foo
		query_src_db "create table $src_tbl_1(i int)" > /dev/null
		query_src_db "create table $src_tbl_2(i int)"
		query_src_db "create table $src_tbl_3(i int)"
		query_dst_db "create table $dst_tbl(i int)"
		query_src_db "insert into $src_tbl_1 values(1)"
		query_src_db "insert into $src_tbl_2 values(2)"
		query_src_db "insert into $src_tbl_3 values(3)"
		trap "query_src_db 'drop table $src_tbl_1';\
			query_src_db 'drop table $src_tbl_2';\
			query_src_db 'drop table $src_tbl_3';\
			query_dst_db 'drop table $dst_tbl'" EXIT

		# When
		query_dst_db "import $src_tbl_1 from LOCAL_$SRC_DBNAME to $dst_tbl" && \
		query_dst_db "import $src_tbl_2 from LOCAL_$SRC_DBNAME to $dst_tbl" && \
		query_dst_db "import $src_tbl_3 from LOCAL_$SRC_DBNAME to $dst_tbl"

		# Then
		verify $? $src_tbl_3 $dst_tbl
	)
}

function test_multiple_imports_at_once() {
	(
		# Given
		local src_tbl dst_tbl n_simultaneous_imports pids rc
		fixture_src_tbl_and_dst_tbl_are_the_same src_tbl dst_tbl
		n_simultaneous_imports=8 pids=() rc=0
		trap "query_src_db 'drop table $src_tbl'; query_dst_db 'drop table $dst_tbl'" EXIT

		# When
		for i in $(seq $n_simultaneous_imports); do
			query_dst_db "import $src_tbl from LOCAL_$SRC_DBNAME to $dst_tbl" &
			pids[${i}]=$!
		done

		for pid in ${pids[@]}; do
			wait $pid || rc=1
		done

		# Then
		verify $rc $src_tbl $dst_tbl
	)
}

function test_mutual_simultaneous_import() {
	(
		# Given
		local src_tbl dst_tbl n_simultaneous_imports pids rc
		fixture_src_tbl_and_dst_tbl_are_the_same src_tbl dst_tbl
		n_mutual_imports=8 pids=() rc=0
		trap "query_src_db 'drop table $src_tbl'; query_dst_db 'drop table $dst_tbl'" EXIT

		# When
		for i in $(seq 1 2 $n_mutual_imports); do
			query_dst_db "import $src_tbl from LOCAL_$SRC_DBNAME to $dst_tbl" &
			pids[${i}]=$!

			query_src_db "import $dst_tbl from LOCAL_$DST_DBNAME to $src_tbl" &
			pids[$((i+1))]=$!
		done

		for pid in ${pids[@]}; do
			wait $pid || rc=1
		done

		# Then
			# We should have one or the other of the original tables
		verify $rc $src_tbl $dst_tbl || verify $rc $dst_tbl $src_tbl
	)
}

function test_heavy_traffic_import() {
	(
		# Given
		local src_tbl dst_tbl n_insert_threads src_pids dst_pids rc
		fixture_src_tbl_and_dst_tbl_are_the_same src_tbl dst_tbl
		src_pids=() dst_pids=() n_insert_threads=7 rc=0
		trap "query_src_db 'drop table $src_tbl'; query_dst_db 'drop table $dst_tbl'" EXIT

		for i in $(seq $n_insert_threads); do
			query_in_loop query_src_db "insert into $src_tbl values(abs(random())%10000)" .1 &
			src_pids[${i}]=$!

			query_in_loop query_dst_db "insert into $dst_tbl values(abs(random())%10000)" .1 &
			dst_pids[${i}]=$!
		done

		sleep 1

		src_values=$(query_src_db_opts "select * from $src_tbl" "-tabs")

		# When
		query_dst_db "import $src_tbl from LOCAL_$SRC_DBNAME to $dst_tbl"

		# Then
		rc=$?

		for pid in ${src_pids[@]} ${dst_pids[@]};
		do
			if ! ps -p $pid > /dev/null;
			then
				# PID failed
				rc=1
				break
			fi
			kill -9 $pid &> /dev/null
		done

		verify $rc $src_tbl $dst_tbl "$src_values"
	)
}

function run_basic_test() {
	(
		# Given
		local src_tbl dst_tbl
		$1 src_tbl dst_tbl
		trap "query_src_db 'drop table $src_tbl'; query_dst_db 'drop table $dst_tbl'" EXIT

		# When
		query_dst_db "import $src_tbl from LOCAL_$SRC_DBNAME to $dst_tbl" 

		# Then
		rc=$?

		if [ "$TESTCASE" == "bulkimport_mismatched_blobstripe_generated" -o \
	 		 "$TESTCASE" == "bulkimport_mismatched_dtastripe_generated" ]; then
			rc=$(( ! $rc )) # Databases with mismatched configs should fail every import.
		else
			verify $rc $src_tbl $dst_tbl
			rc=$?
		fi

		return $rc
	)
}

function test_basic() {
	for fixture in $FIXTURES;
	do
		run_basic_test $fixture
		rc=$?

		if (( rc != 0 ));
		then
			echo_err "Failed $FUNCNAME with $fixture"
			return $rc
		fi
	done
}

if [ "$TESTCASE" == "bulkimport_mismatched_blobstripe_generated" -o \
	 "$TESTCASE" == "bulkimport_mismatched_dtastripe_generated" ]; then
	TESTS="test_basic"
else
	TESTS=$(compgen -A function | grep -oh "test_\w*")
fi

function main() {
	for testcase in $TESTS;
	do
		$testcase
		failexit $? "Failed $testcase"
		echo_err "Passed $testcase"
	done
}

main
