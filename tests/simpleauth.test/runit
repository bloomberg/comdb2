#!/usr/bin/env bash
bash -n "$0" | exit 1

set -e
source ${TESTSROOTDIR}/tools/runit_common.sh

dbnm=$1

if [ "x$dbnm" == "x" ] ; then
    failexit "need a DB name"
fi

SA="${TESTSBUILDDIR}/simpleauth_test ${dbnm}"
OP="bpi:procauth:cluster:test:user:op:bpkg:setup"
MOHIT="bpi:procauth:cluster:testcluster:user:mohit:bpkg:myapp"
MIKE="bpi:procauth:cluster:prod:user:mike:bpkg:cdb2sql"
MARK="bpi:procauth:cluster:test:user:mk:bpkg:myapp"

passed=0
failed=0

run_expect_success() {
    local principal="$1"
    local sql="$2"
    local desc="$3"
    if $SA "$principal" "$sql" > /dev/null 2>&1; then
        echo "  PASS: $desc"
        passed=$((passed + 1))
    else
        echo "  FAIL: $desc"
        failed=$((failed + 1))
    fi
}

run_expect_failure() {
    local principal="$1"
    local sql="$2"
    local desc="$3"
    if $SA "$principal" "$sql" > /dev/null 2>&1; then
        echo "  FAIL: $desc (expected failure but succeeded)"
        failed=$((failed + 1))
    else
        echo "  PASS: $desc"
        passed=$((passed + 1))
    fi
}

#---------------------------------------------------------------
echo "Test: setup comdb2_simple_auth table"
#---------------------------------------------------------------
run_expect_success "$OP" "create table if not exists comdb2_simple_auth(cluster cstring(20) default '*', user cstring(20) default '*', bpkg cstring(50) default '*', verb cstring(20) default '*', resourcetype cstring(20) default '*', resourcename cstring(50) default '*')" \
    "create auth table"
run_expect_success "$OP" "create unique index if not exists comdb2_simple_auth_ix on comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename)" \
    "create auth index"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "insert wildcard rule"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', 'Connect', '*', '*') on conflict do nothing" \
    "insert Connect rule"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "insert Read rule for auth table"

#---------------------------------------------------------------
echo "Test: principal parsing with different identities"
#---------------------------------------------------------------
run_expect_success "$OP" "create table if not exists t1(i int)" \
    "create test table t1"
run_expect_success "$OP" "insert into t1 values(1)" \
    "insert into t1"
run_expect_success "$MOHIT" "select * from t1" \
    "mohit can read t1 (wildcard allows)"
run_expect_success "$MIKE" "select * from t1" \
    "mike can read t1 (wildcard allows)"

#---------------------------------------------------------------
echo "Test: restricted access after removing wildcard"
#---------------------------------------------------------------
# Grant op access to auth table before removing wildcard
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mohit', '*', 'Read', 'table', 't1') on conflict do nothing" \
    "add mohit Read rule for t1"

run_expect_success "$MOHIT" "select * from t1" \
    "mohit can read t1 (specific rule)"
run_expect_failure "$MIKE" "select * from t1" \
    "mike cannot read t1 (no matching rule)"

# Restore
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user = 'op' or user = 'mohit'" \
    "clean up user-specific rules"

#---------------------------------------------------------------
echo "Test: verb-specific permissions (Read vs Write)"
#---------------------------------------------------------------
# Grant op access to auth table before removing wildcard
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"

# mk gets Read-only on t1
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mk', '*', 'Read', 'table', 't1') on conflict do nothing" \
    "add mk Read rule for t1"
run_expect_success "$MARK" "select * from t1" \
    "mk can read t1"
run_expect_failure "$MARK" "insert into t1 values(2)" \
    "mk cannot write t1 (no Write rule)"

# Now grant mk Write
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mk', '*', 'Write', 'table', 't1') on conflict do nothing" \
    "add mk Write rule for t1"
run_expect_success "$MARK" "insert into t1 values(2)" \
    "mk can write t1 (Write rule added)"

# Restore
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user != '*'" \
    "clean up user-specific rules"

#---------------------------------------------------------------
echo "Test: UDF access bypasses simpleauth, stored procedures do not"
#---------------------------------------------------------------

# Create procedures and register UDFs while wildcard allows it
run_expect_success "$OP" "create procedure myadd version 'test' {local function myadd(a, b) return a + b end}" \
    "create myadd procedure for scalar UDF"
run_expect_success "$OP" "create lua scalar function myadd" \
    "register myadd as scalar UDF"
run_expect_success "$OP" "create procedure mysum version 'test' {local agg = 0 local function step(v) agg = agg + v end local function final() return agg end}" \
    "create mysum procedure for aggregate UDF"
run_expect_success "$OP" "create lua aggregate function mysum" \
    "register mysum as aggregate UDF"
run_expect_success "$OP" "create procedure myproc version 'test' {local function main() db:column_name('result', 1) db:column_type('text', 1) db:emit('hello') end}" \
    "create myproc stored procedure"
run_expect_success "$OP" "create table if not exists t_udf(i int)" \
    "create t_udf table"
run_expect_success "$OP" "insert into t_udf values(10),(20),(30)" \
    "populate t_udf"

# Verify everything works with wildcard in place
run_expect_success "$MARK" "select myadd(1, 2)" \
    "mk can call scalar UDF (wildcard allows)"
run_expect_success "$MARK" "select mysum(i) from t_udf" \
    "mk can call aggregate UDF (wildcard allows)"
run_expect_success "$MARK" "exec procedure myproc()" \
    "mk can exec procedure (wildcard allows)"

# Set up restricted access: remove wildcard, grant mk only table access
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"

# Give mk Read access to t_udf table only (no stored-procedure access)
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mk', '*', 'Read', 'table', 't_udf') on conflict do nothing" \
    "add mk Read rule for t_udf"

# mk can call scalar UDF (no table involved, UDFs bypass auth entirely)
run_expect_success "$MARK" "select myadd(1, 2)" \
    "mk can call scalar UDF without stored-procedure access (UDFs bypass auth)"

# mk can call aggregate UDF on t_udf (table Read is enough, UDF itself needs no auth)
run_expect_success "$MARK" "select mysum(i) from t_udf" \
    "mk can call aggregate UDF with table access (UDFs bypass auth)"

# mk cannot exec stored procedure (stored procedures check auth, no matching rule)
run_expect_failure "$MARK" "exec procedure myproc()" \
    "mk cannot exec procedure without stored-procedure Read rule"

# Restore and cleanup
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user = 'op' or user = 'mk'" \
    "clean up user-specific rules"
run_expect_success "$OP" "drop lua scalar function myadd" \
    "drop myadd UDF"
run_expect_success "$OP" "drop lua aggregate function mysum" \
    "drop mysum UDF"
run_expect_success "$OP" "drop procedure myadd version 'test'" \
    "drop myadd procedure"
run_expect_success "$OP" "drop procedure mysum version 'test'" \
    "drop mysum procedure"
run_expect_success "$OP" "drop procedure myproc version 'test'" \
    "drop myproc procedure"
run_expect_success "$OP" "drop table if exists t_udf" \
    "drop t_udf table"

#---------------------------------------------------------------
echo "Test: anonymous access"
#---------------------------------------------------------------
ANON="bpi:anonymous"

run_expect_success "$ANON" "select * from t1" \
    "anonymous can read t1 (wildcard allows)"

# Remove wildcard, grant op access to auth table
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"

run_expect_failure "$ANON" "select * from t1" \
    "anonymous cannot read t1 (no matching rule)"

# Restore
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user = 'op'" \
    "clean up op rules"

#---------------------------------------------------------------
echo "Test: verify simpleauth logs client_info with IP for anonymous"
#---------------------------------------------------------------
found_log=0
if [ -n "$CLUSTER" ] ; then
    for node in $(getclusternodes) ; do
        logfile="${TESTDIR}/logs/${dbnm}.${node}.db"
        if grep -q "simpleauth: principal='bpi:anonymous' client_info='.*:ip:" "$logfile" 2>/dev/null; then
            found_log=1
            break
        fi
    done
else
    logfile="${TESTDIR}/logs/${dbnm}.db"
    if grep -q "simpleauth: principal='bpi:anonymous' client_info='.*:ip:" "$logfile" 2>/dev/null; then
        found_log=1
    fi
fi
if [ $found_log -eq 1 ]; then
    echo "  PASS: server log shows anonymous principal with IP in client_info"
    passed=$((passed + 1))
else
    echo "  FAIL: server log missing anonymous client_info with IP"
    failed=$((failed + 1))
fi

#---------------------------------------------------------------
echo "Test: cleanup"
#---------------------------------------------------------------
run_expect_success "$OP" "drop table if exists t1" \
    "drop test table"

echo ""
echo "Results: $passed passed, $failed failed"

if [ $failed -gt 0 ] ; then
    failexit "$failed tests failed"
fi

echo "Success"
exit 0
